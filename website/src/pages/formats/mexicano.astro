---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormatPage from '../../components/pages/FormatPage.astro';
import { getPages } from '../../i18n';
import { breadcrumbSchema } from '../../i18n/pageSchema';

const f = getPages('en').formats.items.mexicano;
const crumb = breadcrumbSchema([
  { name: 'Home', path: '/' },
  { name: f.name, path: '/formats/mexicano' },
]);
---

<BaseLayout title={f.metaTitle} description={f.metaDesc} enPath="/formats/mexicano" idPath="/id/format/mexicano" schema={crumb}>
  <FormatPage formatKey="mexicano" />
</BaseLayout>
