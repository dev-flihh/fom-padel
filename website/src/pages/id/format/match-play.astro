---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import FormatPage from '../../../components/pages/FormatPage.astro';
import { getPages } from '../../../i18n';
import { breadcrumbSchema } from '../../../i18n/pageSchema';

const f = getPages('id').formats.items['match-play'];
const crumb = breadcrumbSchema([
  { name: 'Home', path: '/id/' },
  { name: f.name, path: '/id/format/match-play' },
]);
---

<BaseLayout title={f.metaTitle} description={f.metaDesc} enPath="/formats/match-play" idPath="/id/format/match-play" schema={crumb}>
  <FormatPage formatKey="match-play" />
</BaseLayout>
