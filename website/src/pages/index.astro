---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/home/Hero.astro';
import ProofStrip from '../components/home/ProofStrip.astro';
import ToxicSpotlight from '../components/home/ToxicSpotlight.astro';
import RankingSpotlight from '../components/home/RankingSpotlight.astro';
import FeatureBento from '../components/home/FeatureBento.astro';
import RewindShowcase from '../components/home/RewindShowcase.astro';
import HowItWorks from '../components/home/HowItWorks.astro';
import Formats from '../components/home/Formats.astro';
import Testimonials from '../components/home/Testimonials.astro';
import BlogPreview from '../components/home/BlogPreview.astro';
import Faq from '../components/home/Faq.astro';
import FinalCta from '../components/home/FinalCta.astro';
import { getHomeSchema } from '../i18n/homeSchema';
---

<BaseLayout enPath="/" idPath="/id/" schema={getHomeSchema('en')}>
  <Hero />
  <ProofStrip />
  <ToxicSpotlight />
  <RankingSpotlight />
  <FeatureBento />
  <RewindShowcase />
  <HowItWorks />
  <Formats />
  <Testimonials />
  <BlogPreview />
  <Faq />
  <FinalCta />
</BaseLayout>
