---
import Icon from '../Icon.astro';
import { getPages } from '../../i18n';

const p = getPages(Astro.currentLocale).faq;
---

<section class="border-b border-outline bg-surface/50">
  <div class="mx-auto max-w-3xl px-4 py-14 text-center sm:px-6 lg:py-20">
    <span class="inline-flex items-center gap-2 rounded-full border border-outline bg-white px-3.5 py-1.5 text-xs font-medium text-muted">
      <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
      FAQ
    </span>
    <h1 class="heading mt-6 text-4xl sm:text-5xl">{p.title}</h1>
    <p class="mt-4 text-muted">{p.subtitle}</p>
  </div>
</section>

<section class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:py-16">
  {p.groups.map((group) => (
    <div class="mb-8">
      <h2 class="text-sm font-bold tracking-wider text-primary uppercase" data-reveal>{group.category}</h2>
      <div class="mt-4 divide-y divide-outline rounded-xl border border-outline bg-white shadow-sm" data-reveal>
        {group.items.map((item) => (
          <details class="faq-item px-5 py-4">
            <summary class="flex items-center justify-between gap-4 text-sm font-semibold text-ink sm:text-base">
              {item.q}
              <span class="faq-chevron shrink-0 text-gray-400"><Icon name="chevron-down" size={16} /></span>
            </summary>
            <p class="mt-3 text-sm leading-relaxed text-muted">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  ))}
</section>
