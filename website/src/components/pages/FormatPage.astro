---
import Icon from '../Icon.astro';
import { getPages } from '../../i18n';

interface Props {
  formatKey: 'americano' | 'mexicano' | 'match-play';
}

const { formatKey } = Astro.props;
const locale = Astro.currentLocale;
const formats = getPages(locale).formats;
const f = formats.items[formatKey];
const c = formats.common;

const basePrefix = locale === 'id' ? '/id/format/' : '/formats/';
const others = (['americano', 'mexicano', 'match-play'] as const).filter((k) => k !== formatKey);

const accent = formatKey === 'americano' ? 'americano' : formatKey === 'match-play' ? 'matchplay' : 'primary';
const barClass = accent === 'americano' ? 'bg-americano' : accent === 'matchplay' ? 'bg-matchplay' : 'bg-primary';
const textClass = accent === 'americano' ? 'text-americano' : accent === 'matchplay' ? 'text-matchplay' : 'text-primary';
---

<!-- Hero -->
<section class="border-b border-outline">
  <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:py-20">
    <nav class="flex items-center gap-1.5 text-xs font-medium text-gray-400">
      <a href={locale === 'id' ? '/id/' : '/'} class="hover:text-ink">Home</a>
      <span>/</span>
      <span class="text-gray-500">{f.name}</span>
    </nav>
    <div class:list={['mt-6 h-1 w-12 rounded-full', barClass]}></div>
    <h1 class="heading mt-4 text-4xl sm:text-6xl">{f.name}</h1>
    <p class:list={['mt-2 text-lg font-semibold', textClass]}>{f.tagline}</p>
    <p class="mt-5 max-w-2xl text-base leading-relaxed text-muted sm:text-lg">{f.intro}</p>
  </div>
</section>

<!-- How it plays + best for -->
<section class="border-b border-outline bg-surface/50">
  <div class="mx-auto grid max-w-5xl gap-8 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:py-20">
    <div class="rounded-xl border border-outline bg-white p-6 shadow-sm" data-reveal>
      <h2 class="text-sm font-bold tracking-wider text-gray-400 uppercase">{c.howLabel}</h2>
      <ol class="mt-4 grid gap-3">
        {f.how.map((step, i) => (
          <li class="flex gap-3 text-sm leading-relaxed text-gray-700">
            <span class:list={['flex h-6 w-6 shrink-0 items-center justify-center rounded-full text-[11px] font-bold text-white', barClass]}>{i + 1}</span>
            {step}
          </li>
        ))}
      </ol>
    </div>
    <div class="grid gap-4" data-reveal>
      <div class="rounded-xl border border-outline bg-white p-6 shadow-sm">
        <h2 class="text-sm font-bold tracking-wider text-gray-400 uppercase">{c.bestForLabel}</h2>
        <ul class="mt-4 grid gap-2.5">
          {f.bestFor.map((item) => (
            <li class="flex items-start gap-2.5 text-sm leading-relaxed text-gray-700">
              <Icon name="check" size={16} class={`mt-0.5 shrink-0 ${textClass}`} />
              {item}
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-xl border border-outline bg-white p-6 shadow-sm">
        <h2 class="text-sm font-bold tracking-wider text-gray-400 uppercase">{c.scoringLabel}</h2>
        <p class="mt-3 text-sm leading-relaxed text-gray-700">{f.scoring}</p>
      </div>
    </div>
  </div>
</section>

<!-- Other formats + CTA -->
<section class="mx-auto max-w-5xl px-4 py-16 sm:px-6 lg:py-20">
  <div class="grid gap-8 lg:grid-cols-[1fr_1fr] lg:items-center">
    <div>
      <h2 class="text-sm font-bold tracking-wider text-gray-400 uppercase" data-reveal>{c.otherFormats}</h2>
      <div class="mt-4 grid gap-3" data-reveal>
        {others.map((k) => (
          <a href={`${basePrefix}${k}`} class="group flex items-center justify-between rounded-xl border border-outline bg-white p-4 shadow-sm transition-colors hover:border-gray-300">
            <div>
              <p class="text-sm font-semibold text-ink group-hover:text-primary">{formats.items[k].name}</p>
              <p class="text-xs text-muted">{formats.items[k].tagline}</p>
            </div>
            <Icon name="arrow-right" size={16} class="text-gray-400 group-hover:text-primary" />
          </a>
        ))}
      </div>
    </div>
    <div class="dot-grid-dark rounded-2xl bg-navy-deep px-6 py-12 text-center text-white" data-reveal>
      <h2 class="heading text-2xl text-white sm:text-3xl">{c.ctaTitle}</h2>
      <a href="/app" class="mt-6 inline-flex h-11 items-center gap-2 rounded-md bg-primary px-6 text-sm font-semibold text-white transition-colors hover:bg-primary-strong">
        {c.ctaButton}
        <Icon name="arrow-right" size={15} />
      </a>
    </div>
  </div>
</section>
