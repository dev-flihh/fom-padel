---
import Icon from '../Icon.astro';
import { getDict } from '../../i18n';

const t = getDict(Astro.currentLocale);

// Tier tertinggi diberi aksen; sisanya netral ala Streamline.
const tierStyles = [
  'border-outline bg-white text-gray-500',
  'border-outline bg-white text-gray-500',
  'border-outline bg-white text-gray-600',
  'border-outline bg-white text-gray-600',
  'border-outline bg-white text-gray-700',
  'border-outline bg-white text-gray-700',
  'border-primary/40 bg-primary/[0.06] text-primary',
];

const board = [
  { rank: 1, name: 'Dinda P.', city: 'Jakarta', mmr: 2140, delta: '+24' },
  { rank: 2, name: 'Kevin S.', city: 'Bandung', mmr: 2087, delta: '+12' },
  { rank: 3, name: 'Sasha R.', city: 'Jakarta', mmr: 2031, delta: '−8' },
  { rank: 4, name: 'Yoga A.', city: 'Surabaya', mmr: 1988, delta: '+31' },
  { rank: 5, name: 'Marco T.', city: 'Bali', mmr: 1954, delta: '+5' },
];
---

<section id="ranking" class="border-b border-outline">
  <div class="mx-auto grid max-w-6xl items-center gap-12 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:py-24">
    <div data-reveal>
      <span class="inline-flex items-center gap-2 rounded-full border border-outline bg-white px-3.5 py-1.5 text-xs font-medium text-muted">
        <Icon name="trending-up" size={13} class="text-primary" />
        {t.ranking.eyebrow}
      </span>
      <h2 class="heading mt-5 text-3xl sm:text-5xl">{t.ranking.title}</h2>
      <p class="mt-4 max-w-lg text-base leading-relaxed text-muted sm:text-lg">{t.ranking.body}</p>

      <!-- 7 tier -->
      <div class="mt-7 flex flex-wrap gap-2">
        {t.ranking.tiers.map((tier, i) => (
          <span class:list={['rounded-full border px-3 py-1 text-xs font-medium', tierStyles[i]]}>
            {tier}
          </span>
        ))}
      </div>

      <a
        href="#faq"
        class="mt-8 inline-flex h-10 items-center gap-2 rounded-md border border-outline bg-white px-5 text-sm font-semibold text-ink transition-colors hover:border-gray-300 hover:bg-surface"
      >
        {t.ranking.cta}
        <Icon name="arrow-right" size={15} />
      </a>
    </div>

    <!-- Kartu leaderboard -->
    <div class="rounded-xl border border-outline bg-white p-5 shadow-sm sm:p-6" data-reveal>
      <div class="flex items-center justify-between">
        <p class="text-sm font-semibold text-ink">{t.ranking.boardTitle}</p>
        <div class="flex rounded-md border border-outline bg-surface p-0.5 text-xs font-medium">
          <span class="inline-flex items-center gap-1 rounded bg-white px-3 py-1.5 font-semibold text-ink shadow-sm">
            <Icon name="globe" size={12} />
            {t.ranking.toggleGlobal}
          </span>
          <span class="inline-flex items-center gap-1 px-3 py-1.5 text-gray-400">
            <Icon name="map-pin" size={12} />
            {t.ranking.toggleCity}
          </span>
        </div>
      </div>

      <div class="mt-4 divide-y divide-outline rounded-lg border border-outline">
        {board.map((row) => (
          <div class:list={['flex items-center gap-3 px-3.5 py-3', row.rank === 1 && 'bg-primary/[0.03]']}>
            <span
              class:list={[
                'flex h-6 w-6 shrink-0 items-center justify-center rounded-full text-[11px] font-bold',
                row.rank === 1 ? 'bg-primary text-white' : 'bg-surface text-gray-500',
              ]}
            >
              {row.rank}
            </span>
            <div class="min-w-0 flex-1">
              <p class="truncate text-sm font-semibold text-ink">{row.name}</p>
              <p class="text-[11px] text-gray-400">{row.city}</p>
            </div>
            <div class="text-right">
              <p class="text-sm font-bold text-ink">{row.mmr}</p>
              <p class="text-[10px] tracking-wide text-gray-400 uppercase">{t.ranking.mmrLabel}</p>
            </div>
            <span
              class:list={[
                'w-11 rounded-md py-1 text-center text-xs font-bold',
                row.delta.startsWith('+') ? 'bg-americano/10 text-americano' : 'bg-rosefom/10 text-rosefom',
              ]}
            >
              {row.delta}
            </span>
          </div>
        ))}
      </div>

      <!-- Sparkline MMR -->
      <div class="mt-4 rounded-lg border border-outline bg-surface/60 p-4">
        <p class="text-[11px] font-semibold tracking-wide text-gray-400 uppercase">Dinda P. — {t.ranking.mmrLabel}</p>
        <svg viewBox="0 0 260 56" class="mt-1 h-14 w-full" preserveAspectRatio="none">
          <path
            class="sparkline-path"
            d="M4 44 L36 40 L68 46 L100 32 L132 36 L164 22 L196 26 L228 12 L256 8"
            fill="none"
            stroke="#E65E14"
            stroke-width="2.5"
            stroke-linecap="round"
          ></path>
          <circle cx="256" cy="8" r="3.5" fill="#E65E14"></circle>
        </svg>
      </div>
    </div>
  </div>
</section>
