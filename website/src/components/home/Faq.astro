---
import Icon from '../Icon.astro';
import { getDict } from '../../i18n';

const t = getDict(Astro.currentLocale);
---

<section id="faq" class="border-b border-outline bg-surface/50">
  <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:py-24">
    <h2 class="heading text-center text-3xl sm:text-4xl" data-reveal>{t.faq.title}</h2>
    <div class="mt-10 divide-y divide-outline rounded-xl border border-outline bg-white shadow-sm" data-reveal>
      {t.faq.items.map((item) => (
        <details class="faq-item px-5 py-4">
          <summary class="flex items-center justify-between gap-4 text-sm font-semibold text-ink sm:text-base">
            {item.q}
            <span class="faq-chevron shrink-0 text-gray-400">
              <Icon name="chevron-down" size={16} />
            </span>
          </summary>
          <p class="mt-3 text-sm leading-relaxed text-muted">{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
