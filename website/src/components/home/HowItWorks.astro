---
import { getDict } from '../../i18n';

const t = getDict(Astro.currentLocale);
---

<section class="border-b border-outline bg-surface/50">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-24">
    <h2 class="heading max-w-xl text-3xl sm:text-5xl" data-reveal>{t.how.title}</h2>
    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {t.how.steps.map((step, i) => (
        <div class="rounded-xl border border-outline bg-white p-6 shadow-sm" data-reveal>
          <span class="flex h-9 w-9 items-center justify-center rounded-full border border-primary/30 bg-primary/[0.06] text-sm font-bold text-primary">
            {i + 1}
          </span>
          <h3 class="mt-4 text-base font-semibold text-ink">{step.name}</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-muted">{step.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
