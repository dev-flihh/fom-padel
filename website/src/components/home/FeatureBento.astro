---
import Icon from '../Icon.astro';
import { getDict } from '../../i18n';

const t = getDict(Astro.currentLocale);
const c = t.bento.cards;
---

<section id="features" class="border-b border-outline bg-surface/50">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-24">
    <div class="max-w-2xl" data-reveal>
      <h2 class="heading text-3xl sm:text-5xl">{t.bento.title}</h2>
      <p class="mt-4 text-base leading-relaxed text-muted sm:text-lg">{t.bento.subtitle}</p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-6">
      <!-- Live scoring (besar) -->
      <div class="rounded-xl border border-outline bg-white p-6 shadow-sm sm:col-span-2 lg:col-span-4" data-reveal>
        <div class="flex flex-wrap items-start justify-between gap-6">
          <div class="max-w-sm">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-outline bg-surface text-primary">
              <Icon name="zap" size={18} />
            </div>
            <h3 class="mt-4 text-base font-semibold text-ink">{c.liveScoring.title}</h3>
            <p class="mt-1.5 text-sm leading-relaxed text-muted">{c.liveScoring.desc}</p>
          </div>
          <!-- Mini kartu skor -->
          <div class="w-full max-w-[240px] rounded-lg border border-outline bg-white p-4 shadow-sm">
            <div class="flex items-center justify-between text-[11px] font-medium text-gray-400">
              <span>Court 2 · R5</span>
              <span class="inline-flex items-center gap-1 font-semibold text-primary">
                <span class="ticker-dot h-1.5 w-1.5 rounded-full bg-primary"></span>
                Live
              </span>
            </div>
            <div class="mt-3 grid gap-1.5 text-sm font-semibold text-ink">
              <div class="flex items-center justify-between rounded-md bg-surface px-3 py-2">
                <span>Dinda / Raka</span><span class="text-lg text-primary">9</span>
              </div>
              <div class="flex items-center justify-between rounded-md bg-surface px-3 py-2">
                <span>Yoga / Budi</span><span class="text-lg text-gray-400">4</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Klasemen otomatis -->
      <div class="rounded-xl border border-outline bg-white p-6 shadow-sm lg:col-span-2" data-reveal>
        <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-outline bg-surface text-primary">
          <Icon name="bar-chart" size={18} />
        </div>
        <h3 class="mt-4 text-base font-semibold text-ink">{c.standings.title}</h3>
        <p class="mt-1.5 text-sm leading-relaxed text-muted">{c.standings.desc}</p>
        <div class="mt-4 grid gap-1.5">
          {['w-full', 'w-4/5', 'w-3/5'].map((w, i) => (
            <div class="flex items-center gap-2">
              <span class="w-3 text-[10px] font-semibold text-gray-400">{i + 1}</span>
              <div class:list={['h-2 rounded-full', w, i === 0 ? 'bg-primary' : 'bg-outline']}></div>
            </div>
          ))}
        </div>
      </div>

      <!-- Share tanpa login -->
      <div class="rounded-xl border border-outline bg-white p-6 shadow-sm lg:col-span-2" data-reveal>
        <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-outline bg-surface text-primary">
          <Icon name="link" size={18} />
        </div>
        <h3 class="mt-4 text-base font-semibold text-ink">{c.share.title}</h3>
        <p class="mt-1.5 text-sm leading-relaxed text-muted">{c.share.desc}</p>
        <div class="mt-4 flex items-center gap-2 rounded-md border border-dashed border-gray-300 bg-surface px-3.5 py-2.5 text-xs font-medium text-gray-600">
          fomplay.asia/s/fri-night
          <span class="ml-auto rounded bg-primary px-2 py-0.5 text-[10px] font-semibold text-white">OPEN</span>
        </div>
      </div>

      <!-- FOM Rewind -->
      <div class="rounded-xl border border-outline bg-white p-6 shadow-sm lg:col-span-2" data-reveal>
        <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-outline bg-surface text-primary">
          <Icon name="camera" size={18} />
        </div>
        <h3 class="mt-4 text-base font-semibold text-ink">{c.rewind.title}</h3>
        <p class="mt-1.5 text-sm leading-relaxed text-muted">{c.rewind.desc}</p>
        <div class="mt-4 flex gap-2">
          {['rewind-cover', 'rewind-podium', 'rewind-cupu'].map((name) => (
            <img
              src={`/screenshots/${name}.png`}
              alt=""
              loading="lazy"
              class="h-16 w-auto rounded-md border border-outline"
            />
          ))}
        </div>
      </div>

      <!-- Rooms & split bill -->
      <div class="rounded-xl border border-outline bg-white p-6 shadow-sm lg:col-span-2" data-reveal>
        <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-outline bg-surface text-primary">
          <Icon name="coins" size={18} />
        </div>
        <h3 class="mt-4 text-base font-semibold text-ink">{c.rooms.title}</h3>
        <p class="mt-1.5 text-sm leading-relaxed text-muted">{c.rooms.desc}</p>
        <div class="mt-4 flex items-center justify-between rounded-md border border-outline bg-surface px-3.5 py-2.5 text-xs font-medium">
          <span class="text-gray-500">Court + balls</span>
          <span class="font-semibold text-ink">Rp420k ÷ 8 = <span class="text-primary">Rp52.500</span></span>
        </div>
      </div>

      <!-- 3 format (full-width, horizontal) -->
      <div class="rounded-xl border border-outline bg-white p-6 shadow-sm sm:col-span-2 lg:col-span-6" data-reveal>
        <div class="flex flex-wrap items-center justify-between gap-4">
          <div class="flex items-center gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg border border-outline bg-surface text-primary">
              <Icon name="shuffle" size={18} />
            </div>
            <div>
              <h3 class="text-base font-semibold text-ink">{c.formats.title}</h3>
              <p class="mt-0.5 text-sm leading-relaxed text-muted">{c.formats.desc}</p>
            </div>
          </div>
          <div class="flex flex-wrap gap-2 text-xs font-medium">
            <span class="rounded-full border border-americano/30 bg-americano/[0.06] px-3 py-1 text-americano">Americano</span>
            <span class="rounded-full border border-primary/30 bg-primary/[0.06] px-3 py-1 text-primary">Mexicano</span>
            <span class="rounded-full border border-matchplay/30 bg-matchplay/[0.06] px-3 py-1 text-matchplay">Match Play</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
