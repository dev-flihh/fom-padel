---
import Icon from '../Icon.astro';
import { getDict } from '../../i18n';
import { getArticles, entrySlug } from '../../lib/blog';

const t = getDict(Astro.currentLocale);
const isId = Astro.currentLocale === 'id';
const base = isId ? '/id/blog' : '/blog';

const articles = (await getArticles(isId ? 'id' : 'en')).slice(0, 3);
---

<section class="border-b border-outline">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-24">
    <div class="flex flex-wrap items-end justify-between gap-4" data-reveal>
      <div>
        <h2 class="heading text-3xl sm:text-5xl">{t.blogPreview.title}</h2>
        <p class="mt-3 text-muted">{t.blogPreview.subtitle}</p>
      </div>
      <a href={base} class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:underline">
        {t.blogPreview.viewAll}
        <Icon name="arrow-right" size={15} />
      </a>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-3">
      {articles.map((article) => (
        <a href={`${base}/${entrySlug(article)}`} class="group flex flex-col rounded-xl border border-outline bg-white p-6 shadow-sm transition-colors hover:border-gray-300" data-reveal>
          <div class="flex h-10 w-10 items-center justify-center rounded-lg border border-outline bg-surface text-primary">
            <Icon name={article.data.icon} size={18} />
          </div>
          <span class="mt-4 block text-xs font-medium text-muted">{article.data.category}</span>
          <h3 class="mt-1.5 text-base leading-snug font-semibold text-ink group-hover:text-primary">{article.data.title}</h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-muted">{article.data.description}</p>
          <p class="mt-4 inline-flex items-center gap-1.5 text-xs font-semibold text-primary">
            {t.blogPreview.readMore}
            <Icon name="arrow-right" size={13} />
          </p>
        </a>
      ))}
    </div>
  </div>
</section>
