---
import Icon from '../Icon.astro';
import PhoneFrame from '../PhoneFrame.astro';
import { getDict } from '../../i18n';

const t = getDict(Astro.currentLocale);
---

<section class="border-b border-outline">
  <div class="mx-auto max-w-6xl px-4 pt-16 pb-0 text-center sm:px-6 lg:pt-24">
    <span class="inline-flex items-center gap-2 rounded-full border border-outline bg-white px-3.5 py-1.5 text-xs font-medium text-muted">
      <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
      {t.hero.eyebrow}
    </span>

    <h1 class="heading mx-auto mt-6 max-w-4xl text-4xl sm:text-6xl">
      {t.hero.title1} {t.hero.title2}<br class="hidden sm:block" />
      <span class="text-primary">{t.hero.title3}</span>
    </h1>

    <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-muted sm:text-lg">
      {t.hero.subtitle}
    </p>

    <!-- Callout fitur ala Streamline -->
    <div class="mx-auto mt-6 flex max-w-2xl flex-wrap items-center justify-center gap-x-5 gap-y-2 text-sm font-medium text-gray-500">
      {t.hero.callouts.map((item) => (
        <span class="inline-flex items-center gap-1.5">
          <Icon name="check" size={15} class="text-primary" />
          {item}
        </span>
      ))}
    </div>

    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a
        href="/app"
        class="inline-flex h-11 items-center gap-2 rounded-md bg-primary px-6 text-sm font-semibold text-white transition-colors hover:bg-primary-strong"
      >
        {t.hero.ctaPrimary}
        <Icon name="arrow-right" size={16} />
      </a>
      <a
        href="#toxic"
        class="inline-flex h-11 items-center rounded-md border border-outline bg-white px-6 text-sm font-semibold text-ink transition-colors hover:border-gray-300 hover:bg-surface"
      >
        {t.hero.ctaSecondary}
      </a>
    </div>
    <p class="mt-4 text-xs text-gray-400">{t.hero.trust}</p>

    <!-- Showcase produk dalam frame -->
    <div class="dot-grid relative mt-14 rounded-t-2xl border border-b-0 border-outline bg-surface px-4 pt-10 sm:px-10" data-reveal>
      <div class="mx-auto flex max-w-4xl items-end justify-center gap-6">
        <!-- Kartu skor live (desktop) -->
        <div class="mb-14 hidden w-52 shrink-0 rounded-xl border border-outline bg-white p-4 text-left shadow-sm lg:block">
          <div class="flex items-center justify-between text-[11px] font-medium text-gray-400">
            <span>Court 1 · R2</span>
            <span class="inline-flex items-center gap-1 font-semibold text-primary">
              <span class="ticker-dot h-1.5 w-1.5 rounded-full bg-primary"></span>
              {t.hero.phoneLive}
            </span>
          </div>
          <div class="mt-3 grid gap-1.5 text-sm font-semibold text-ink">
            <div class="flex items-center justify-between rounded-lg bg-surface px-3 py-2.5">
              <span>Falih / Endo</span><span class="text-lg text-primary">5</span>
            </div>
            <div class="flex items-center justify-between rounded-lg bg-surface px-3 py-2.5">
              <span>Kasyf / Wildan</span><span class="text-lg text-gray-400">0</span>
            </div>
          </div>
        </div>

        <!-- HP: screenshot aplikasi asli (live scoring + Zona Cupu) -->
        <PhoneFrame src="/screenshots/app-live.png" alt="FOM Play live scoring with Zona Cupu ticker" width="w-[260px] sm:w-[280px]" />

        <!-- Kartu ticker cupu (desktop) -->
        <div class="mb-14 hidden w-52 shrink-0 rounded-xl border border-outline bg-white p-4 text-left shadow-sm lg:block">
          <div class="inline-flex items-center gap-1.5 text-[11px] font-semibold text-rosefom">
            <span class="ticker-dot h-1.5 w-1.5 rounded-full bg-rosefom"></span>
            {t.toxic.tickerLabel}
          </div>
          <div class="ticker-items mt-2 h-10 overflow-hidden text-xs leading-snug font-medium text-gray-600">
            {t.toxic.tickerItems.map((item) => (
              <p>{item}</p>
            ))}
          </div>
          <div class="mt-3 flex items-center gap-2 rounded-lg border border-outline bg-surface px-3 py-2">
            <Icon name="trophy" size={14} class="text-primary" />
            <span class="text-xs font-semibold text-ink">Cupu D’Or: Sonya Vera</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
