{
  "functions": [
    {
      "source": "functions"
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/blog-next",
        "destination": "/",
        "type": 302
      },
      {
        "source": "/blog-next/**",
        "destination": "/",
        "type": 302
      },
      {
        "source": "/archive",
        "destination": "/",
        "type": 302
      },
      {
        "source": "/archive/**",
        "destination": "/",
        "type": 302
      }
    ],
    "headers": [
      {
        "source": "/",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "/archive.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "/app",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "/app/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "/sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "/manifest.webmanifest",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/fitur",
        "destination": "/archive.html"
      },
      {
        "source": "/format/americano",
        "destination": "/archive.html"
      },
      {
        "source": "/format/mexicano",
        "destination": "/archive.html"
      },
      {
        "source": "/format/match-play",
        "destination": "/archive.html"
      },
      {
        "source": "/edukasi/perbedaan-americano-vs-mexicano",
        "destination": "/archive.html"
      },
      {
        "source": "/ranking",
        "destination": "/archive.html"
      },
      {
        "source": "/faq",
        "destination": "/archive.html"
      },
      {
        "source": "/archive",
        "destination": "/archive.html"
      },
      {
        "source": "/archive/**",
        "destination": "/archive.html"
      },
      {
        "source": "/app",
        "destination": "/archive.html"
      },
      {
        "source": "/app/**",
        "destination": "/archive.html"
      }
    ]
  },
  "firestore": [
    {
      "database": "ai-studio-27d60198-41b0-4446-92d0-3c510bc94635",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    },
    {
      "database": "fom-play-sg",
      "rules": "firestore.rules",
      "indexes": "firestore.indexes.json"
    }
  ]
}
